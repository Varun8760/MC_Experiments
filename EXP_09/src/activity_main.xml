<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF3E0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GSM Security Dashboard"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/inputRAND"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="8-bit RAND (e.g. 10101010)"
            android:background="@android:drawable/editbox_background_normal"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/inputKi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="8-bit Key Ki (e.g. 11001100)"
            android:background="@android:drawable/editbox_background_normal"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/inputMsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Message to Encrypt (e.g. 11110000)"
            android:background="@android:drawable/editbox_background_normal"
            android:padding="12dp"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnRunSecurity"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="RUN ALGORITHMS"
            android:backgroundTint="#FB8C00"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame">

            <TextView
                android:id="@+id/txtA3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A3 SRES: --"
                android:textSize="16sp"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/txtA8"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A8 Kc: --"
                android:textSize="16sp"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#FFCC80"
                android:layout_marginVertical="10dp"/>

            <TextView
                android:id="@+id/txtA5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A5 CIPHERTEXT: --"
                android:textSize="18sp"
                android:textColor="#E65100"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>